{% doc %}
  @prompt
    a text section, customizable

{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-text-section-{{ ai_gen_id }} {
    padding: {{ block.settings.padding_top }}px 0 {{ block.settings.padding_bottom }}px;
    background-color: {{ block.settings.background_color }};
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-text-section__container-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ai-text-section__heading-{{ ai_gen_id }} {
    color: {{ block.settings.heading_color }};
    font-size: {{ block.settings.heading_size }}px;
    font-weight: {{ block.settings.heading_weight }};
    margin: 0 0 {{ block.settings.heading_margin }}px;
    line-height: 1.2;
  }

  .ai-text-section__content-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.text_size }}px;
    line-height: {{ block.settings.line_height }};
    margin:0;}

  .ai-text-section__content-{{ ai_gen_id }} p {
    margin: 00 1em;
  }

  .ai-text-section__content-{{ ai_gen_id }} p:last-child {
    margin-bottom: 0;
  }

  .ai-text-section__content-{{ ai_gen_id }} h1,
  .ai-text-section__content-{{ ai_gen_id }} h2,
  .ai-text-section__content-{{ ai_gen_id }} h3,
  .ai-text-section__content-{{ ai_gen_id }} h4,
  .ai-text-section__content-{{ ai_gen_id }} h5,
  .ai-text-section__content-{{ ai_gen_id }} h6 {
    color: {{ block.settings.heading_color }};
    margin: 1.5em 0 0.5em;
  }

  .ai-text-section__content-{{ ai_gen_id }} h1:first-child,
  .ai-text-section__content-{{ ai_gen_id }} h2:first-child,
  .ai-text-section__content-{{ ai_gen_id }} h3:first-child,
  .ai-text-section__content-{{ ai_gen_id }} h4:first-child,
  .ai-text-section__content-{{ ai_gen_id }} h5:first-child,
  .ai-text-section__content-{{ ai_gen_id }} h6:first-child {
    margin-top: 0;
  }

  .ai-text-section__content-{{ ai_gen_id }} a {
    color: {{ block.settings.link_color }};
    text-decoration: underline;
  }

  .ai-text-section__content-{{ ai_gen_id }} a:hover {
    color: {{ block.settings.link_hover_color }};
  }

  .ai-text-section__content-{{ ai_gen_id }} ul,
  .ai-text-section__content-{{ ai_gen_id }} ol {
    margin: 1em 0;
    padding-left: 2em;
  }

  .ai-text-section__content-{{ ai_gen_id }} li {
    margin-bottom: 0.5em;
  }

  .ai-text-section__content-{{ ai_gen_id }} blockquote {
    border-left: 4px solid {{ block.settings.link_color }};
    padding-left: 1.5em;
    margin: 1.5em 0;font-style: italic;
  }

  @media screen and (max-width: 749px) {
    .ai-text-section-{{ ai_gen_id }} {
      padding: {{ block.settings.padding_top | times: 0.7 | round }}px 0 {{ block.settings.padding_bottom | times: 0.7 | round }}px;
    }

    .ai-text-section__heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.8 | round }}px;
    }

    .ai-text-section__content-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_size | times: 0.9 | round }}px;
    }
  }
{% endstyle %}

<div class="ai-text-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-text-section__container-{{ ai_gen_id }}">
    {% if block.settings.heading != blank %}
      <h2 class="ai-text-section__heading-{{ ai_gen_id }}">
        {{ block.settings.heading }}
      </h2>
    {% endif %}

    {% if block.settings.content != blank %}
      <div class="ai-text-section__content-{{ ai_gen_id }}">
        {{ block.settings.content }}
      </div>
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "Text section",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Tell your story"
    },
    {
      "type": "richtext",
      "id": "content",
      "label": "Text content",
      "default": "<p>Use this text to share information about your brand with your customers. Describe a product, share announcements, or welcome customers to your store.</p>"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "left"
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Maximum width",
      "min": 400,
      "max": 1200,
      "step": 50,
      "unit": "px",
      "default": 800
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 50
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 50
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#333333"
    },
    {
      "type": "color",
      "id": "link_color",
      "label": "Link color",
      "default": "#0066cc"
    },
    {
      "type": "color",
      "id": "link_hover_color",
      "label": "Link hover color",
      "default": "#004499"
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading size",
      "min": 20,
      "max": 60,
      "step": 2,
      "unit": "px",
      "default": 32
    },
    {
      "type": "select",
      "id": "heading_weight",
      "label": "Heading weight",
      "options": [
        {
          "value": "400",
          "label": "Normal"
        },
        {
          "value": "500",
          "label": "Medium"
        },
        {
          "value": "600",
          "label": "Semi bold"
        },
        {
          "value": "700",
          "label": "Bold"
        }
      ],
      "default": "600"
    },
    {
      "type": "range",
      "id": "heading_margin",
      "label": "Heading bottom margin",
      "min": 0,
      "max": 50,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "text_size",
      "label": "Text size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "line_height",
      "label": "Line height",
      "min": 1.0,
      "max": 2.0,
      "step": 0.1,
      "default": 1.6
    }
  ],
  "presets": [
    {
      "name": "Text section"
    }
  ]
}
{% endschema %}