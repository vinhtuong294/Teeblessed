{% comment %}
  Section: 3D Carousel Responsive + Visibility Toggle
  Author: Gemini AI
  Features: No CDN, Responsive Logic, Mobile/Desktop Visibility Control
{% endcomment %}

<a href="https://teeblessed.com/collections/best-sellers"><div class="carousel-wrapper-{{ section.id }}" style="background-color: {{ section.settings.bg_color }};">
  <div class="carousel-container" id="carousel-{{ section.id }}">
    
    {%- for block in section.blocks -%}
      <div class="carousel-item" {{ block.shopify_attributes }}>
        {%- if block.settings.image != blank -%}
          <img 
            src="{{ block.settings.image | image_url: width: 600 }}" 
            alt="{{ block.settings.image.alt | default: 'Slide Image' }}"
            loading="eager"
            width="300" 
            height="400"
          >
        {%- else -%}
          {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
        {%- endif -%}
      </div>
    {%- endfor -%}

    {%- if section.settings.show_dots -%}
      <div class="nav-dots" id="dots-{{ section.id }}"></div>
    {%- endif -%}
  </div>
</div></a>

<style>
  /* 1. VISIBILITY CONTROL (Tính năng Bật/Tắt) */
  {% unless section.settings.show_on_desktop %}
    @media (min-width: 769px) {
      .carousel-wrapper-{{ section.id }} { display: none !important; }
    }
  {% endunless %}

  {% unless section.settings.show_on_mobile %}
    @media (max-width: 768px) {
      .carousel-wrapper-{{ section.id }} { display: none !important; }
    }
  {% endunless %}

  /* 2. CONTAINER STYLES */
  .carousel-wrapper-{{ section.id }} {
    width: calc(100% + 32px);
    padding: {{ section.settings.padding_y }}px 0;
    overflow: hidden;
    display: flex;
    justify-content: center;
    position: relative;
    margin-top: -5px;
    margin-left: -16px;
  }

  .carousel-container {
    position: relative;
    width: 100%;
    max-width: {{ section.settings.container_width }}px;
    perspective: 1000px;
    display: flex;
    justify-content: center;
    align-items: center;
    overflow: hidden; 
    min-height: 300px;
  }

  .carousel-item {
    position: absolute;
    background-color: #fff;
    border-radius: 15px;
    overflow: hidden;
    {% comment %} box-shadow: 0 10px 25px rgba(0,0,0,0.3); {% endcomment %}
    transition: transform 0.5s cubic-bezier(0.25, 1, 0.5, 1), opacity 0.5s ease, width 0.3s, height 0.3s;
    transform-style: preserve-3d;
    cursor: pointer;
    opacity: 0;
    will-change: transform, opacity;
  }

  .carousel-item img, 
  .carousel-item svg {
    width: 100%; height: 100%; object-fit: cover; display: block; pointer-events: none;
  }

  /* DOTS */
  .nav-dots {
    position: absolute;
    bottom: 10px;
    display: flex;
    gap: 12px;
    z-index: 20;
  }
  .dot {
    width: 8px; height: 8px;
    background: rgba(0,0,0,0.2);
    border-radius: 50%;
    cursor: pointer;
    transition: all 0.3s;
  }
  .dot.active { 
    background: {{ section.settings.dot_color }}; 
    transform: scale(1.3); 
  }
  
  .placeholder-svg { background: #f0f0f0; width: 100%; height: 100%; }

  /* Mobile Padding Adjust */
  @media (max-width: 768px) {
    .carousel-wrapper-{{ section.id }} {
      padding: 30px 0;
    }
  }
</style>

<script>
  (function() {
    function initCarousel_{{ section.id | replace: '-', '_' }}() {
      const containerId = "carousel-{{ section.id }}";
      const wrapperId = ".carousel-wrapper-{{ section.id }}";
      const container = document.getElementById(containerId);
      
      // Kiểm tra xem Section có đang bị ẩn bởi CSS visibility không
      // Nếu đang ẩn (display: none), ta không chạy JS để tiết kiệm tài nguyên
      const wrapper = document.querySelector(wrapperId);
      if (!container || !wrapper || getComputedStyle(wrapper).display === 'none') return;

      const items = container.querySelectorAll('.carousel-item');
      if (items.length === 0) return;
      const dotsContainer = document.getElementById("dots-{{ section.id }}");

      // --- CONFIGURATION OBJECT ---
      const settings = {
        desktop: {
          width: {{ section.settings.item_width }},
          height: {{ section.settings.item_height }},
          translateX: {{ section.settings.translate_x }},
          scale: {{ section.settings.scale_center }}
        },
        mobile: {
          width: {{ section.settings.mobile_item_width }},
          height: {{ section.settings.mobile_item_height }},
          translateX: {{ section.settings.mobile_translate_x }},
          scale: {{ section.settings.mobile_scale_center }}
        },
        common: {
          rotateDeg: {{ section.settings.rotate_deg }},
          autoPlaySpeed: {{ section.settings.autoplay_speed }}
        }
      };

      let config = {}; 
      let totalItems = items.length;
      let currentIndex = Math.floor(totalItems / 2);
      let autoPlayInterval;

      // 1. RESPONSIVE CALCULATOR
      function updateConfig() {
        const isMobile = window.innerWidth < 768;
        const mode = isMobile ? settings.mobile : settings.desktop;
        
        config = {
          w: mode.width, h: mode.height, tx: mode.translateX,
          s: mode.scale, r: settings.common.rotateDeg, speed: settings.common.autoPlaySpeed
        };

        const containerHeight = (config.h * config.s) + 40; 
        container.style.height = containerHeight + "px";

        items.forEach(item => {
          item.style.width = config.w + "px";
          item.style.height = config.h + "px";
        });
        updateCarousel();
      }

      // 2. CREATE DOTS
      if (dotsContainer) {
        dotsContainer.innerHTML = '';
        items.forEach((_, idx) => {
          const dot = document.createElement('div');
          dot.classList.add('dot');
          dot.addEventListener('click', () => {
            currentIndex = idx;
            updateCarousel();
            resetAutoPlay();
          });
          dotsContainer.appendChild(dot);
        });
      }
      const dots = dotsContainer ? dotsContainer.querySelectorAll('.dot') : [];

      // 3. CORE LOGIC
      function updateCarousel() {
        items.forEach((item, index) => {
          let offset = (index - currentIndex);
          if (offset > totalItems / 2) offset -= totalItems;
          if (offset < -totalItems / 2) offset += totalItems;

          item.style.zIndex = 1;
          
          if (offset === 0) { // CENTER
            item.style.transform = `translateX(0) scale(${config.s}) rotateY(0deg)`;
            item.style.zIndex = 20; item.style.opacity = 1; item.style.filter = "blur(0)";
          } 
          else if (offset === -1) { // LEFT
            item.style.transform = `translateX(-${config.tx}px) scale(1) rotateY(${config.r}deg)`;
            item.style.zIndex = 10; item.style.opacity = 0.9; item.style.filter = "blur(0)";
          } 
          else if (offset === 1) { // RIGHT
            item.style.transform = `translateX(${config.tx}px) scale(1) rotateY(-${config.r}deg)`;
            item.style.zIndex = 10; item.style.opacity = 0.9; item.style.filter = "blur(0)";
          } 
          else { // HIDDEN
            const direction = offset > 0 ? 1 : -1;
            const farTx = config.tx + (config.w * 0.5); 
            item.style.transform = `translateX(${direction * farTx}px) scale(0.6) rotateY(0deg)`;
            item.style.opacity = 0; item.style.zIndex = 0;
          }
        });

        if (dots.length > 0) {
          dots.forEach(d => d.classList.remove('active'));
          if(dots[currentIndex]) dots[currentIndex].classList.add('active');
        }
      }

      // 4. NAVIGATION & AUTOPLAY
      function nextSlide() { currentIndex = (currentIndex + 1) % totalItems; updateCarousel(); }
      function prevSlide() { currentIndex = (currentIndex - 1 + totalItems) % totalItems; updateCarousel(); }

      function startAutoPlay() { if(config.speed > 0) autoPlayInterval = setInterval(nextSlide, config.speed); }
      function resetAutoPlay() { clearInterval(autoPlayInterval); startAutoPlay(); }

      // 5. SWIPE LOGIC
      let startX = 0; let isDragging = false;
      const handleStart = (x) => { startX = x; isDragging = true; clearInterval(autoPlayInterval); };
      const handleEnd = (x) => {
        if (!isDragging) return;
        const diff = startX - x;
        if (diff > 40) nextSlide(); else if (diff < -40) prevSlide();
        isDragging = false; startAutoPlay();
      };

      container.addEventListener('touchstart', e => handleStart(e.touches[0].clientX), {passive: true});
      container.addEventListener('touchend', e => handleEnd(e.changedTouches[0].clientX));
      container.addEventListener('mousedown', e => { e.preventDefault(); handleStart(e.clientX); });
      container.addEventListener('mouseup', e => handleEnd(e.clientX));
      container.addEventListener('mouseleave', () => { if(isDragging) { isDragging = false; startAutoPlay(); }});
      
      // INIT
      updateConfig();
      startAutoPlay();
      window.addEventListener('resize', updateConfig);
      
    }
    // FIX 3: Force update khi toàn bộ trang đã load xong (dành cho mạng chậm)
     window.addEventListener('load', () => {
      updateConfig();
    });
    document.addEventListener("DOMContentLoaded", initCarousel_{{ section.id | replace: '-', '_' }});
    document.addEventListener("shopify:section:load", (e) => {
      if (e.detail.sectionId === "{{ section.id }}") initCarousel_{{ section.id | replace: '-', '_' }}();
    });
  })();
</script>

{% schema %}
{
  "name": "3D Carousel Pro",
  "settings": [
    {
      "type": "header",
      "content": "Trạng thái hiển thị"
    },
    {
      "type": "checkbox",
      "id": "show_on_desktop",
      "label": "Hiển thị trên Desktop (PC)",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_on_mobile",
      "label": "Hiển thị trên Mobile (Điện thoại)",
      "default": true
    },
    {
      "type": "header",
      "content": "Cài đặt chung"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Màu nền",
      "default": "#f8f9fa"
    },
    {
      "type": "range",
      "id": "container_width",
      "min": 600,
      "max": 1600,
      "step": 50,
      "unit": "px",
      "label": "Max Width (Desktop)",
      "default": 1000
    },
    {
      "type": "range",
      "id": "padding_y",
      "min": 0,
      "max": 100,
      "step": 10,
      "unit": "px",
      "label": "Padding Top/Bottom",
      "default": 50
    },
    {
      "type": "header",
      "content": "🖥️ Cấu hình Desktop"
    },
    {
      "type": "range",
      "id": "item_width",
      "min": 150,
      "max": 400,
      "step": 10,
      "unit": "px",
      "label": "Chiều rộng ảnh",
      "default": 250
    },
    {
      "type": "range",
      "id": "item_height",
      "min": 200,
      "max": 600,
      "step": 10,
      "unit": "px",
      "label": "Chiều cao ảnh",
      "default": 350
    },
    {
      "type": "range",
      "id": "translate_x",
      "min": 100,
      "max": 500,
      "step": 10,
      "unit": "px",
      "label": "Khoảng cách ảnh bên",
      "default": 220
    },
    {
      "type": "range",
      "id": "scale_center",
      "min": 1.0,
      "max": 2.5,
      "step": 0.1,
      "label": "Scale ảnh giữa",
      "default": 1.5
    },
    {
      "type": "header",
      "content": "📱 Cấu hình Mobile"
    },
    {
      "type": "range",
      "id": "mobile_item_width",
      "min": 100,
      "max": 300,
      "step": 10,
      "unit": "px",
      "label": "Chiều rộng ảnh (Mobile)",
      "default": 160
    },
    {
      "type": "range",
      "id": "mobile_item_height",
      "min": 150,
      "max": 400,
      "step": 10,
      "unit": "px",
      "label": "Chiều cao ảnh (Mobile)",
      "default": 220
    },
    {
      "type": "range",
      "id": "mobile_translate_x",
      "min": 50,
      "max": 200,
      "step": 5,
      "unit": "px",
      "label": "Khoảng cách ảnh bên (Mobile)",
      "default": 110
    },
    {
      "type": "range",
      "id": "mobile_scale_center",
      "min": 1.0,
      "max": 2.0,
      "step": 0.1,
      "label": "Scale ảnh giữa (Mobile)",
      "default": 1.3
    },
    {
      "type": "header",
      "content": "Hiệu ứng & Điều khiển"
    },
    {
      "type": "range",
      "id": "rotate_deg",
      "min": 0,
      "max": 90,
      "step": 5,
      "unit": "deg",
      "label": "Góc xoay (Chung)",
      "default": 45
    },
    {
      "type": "range",
      "id": "autoplay_speed",
      "min": 0,
      "max": 9500,
      "step": 500,
      "unit": "ms",
      "label": "Tốc độ tự động",
      "default": 3000
    },
    {
      "type": "checkbox",
      "id": "show_dots",
      "label": "Hiển thị Dots",
      "default": true
    },
    {
      "type": "color",
      "id": "dot_color",
      "label": "Màu Active Dot",
      "default": "#333333"
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Image Slide",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Chọn hình ảnh"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "3D Carousel Pro",
      "blocks": [
        { "type": "slide" },
        { "type": "slide" },
        { "type": "slide" }
      ]
    }
  ]
}
{% endschema %}