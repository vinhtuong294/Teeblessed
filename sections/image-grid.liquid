{% comment %}
  Section: Simple Image Grid
  Author: Gemini AI
  Description: Responsive Gallery - Desktop 4 columns, Mobile 2 columns.
{% endcomment %}

<style>
  .sig-section-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    background-color: {{ section.settings.bg_color }};
  }

  .sig-container {
    max-width: 1200px; /* Độ rộng chuẩn, có thể sửa */
    margin: 0 auto;
    padding: 0 15px; /* Padding 2 bên mép màn hình */
  }

  {% if section.settings.heading != blank %}
  .sig-heading {
    text-align: center;
    font-size: 28px;
    margin-bottom: 30px;
    font-weight: bold;
    color: #000;
  }
  {% endif %}

  /* CẤU TRÚC LƯỚI (GRID SYSTEM) */
  .sig-grid {
    display: grid;
    /* Mặc định Desktop: 4 cột bằng nhau */
    grid-template-columns: repeat(4, 1fr); 
    /* Khoảng cách giữa các ảnh */
    gap: {{ section.settings.gap }}px; 
  }

  .sig-item {
    position: relative;
    display: block; /* Để thẻ a bao trùm toàn bộ */
    overflow: hidden;
    border-radius: {{ section.settings.border_radius }}px;
    transition: transform 0.3s ease;
  }

  /* Hiệu ứng zoom nhẹ khi di chuột (Option) */
  .sig-item:hover {
    transform: translateY(-5px);
  }

  .sig-item img {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover; /* Đảm bảo ảnh phủ kín khung, không bị méo */
    aspect-ratio: {{ section.settings.aspect_ratio }}; /* Tỉ lệ khung hình (1/1 là vuông) */
  }

  /* RESPONSIVE MOBILE */
  @media screen and (max-width: 768px) {
    .sig-section {
      padding-top: {{ section.settings.padding_top | divided_by: 1.5 }}px;
      padding-bottom: {{ section.settings.padding_bottom | divided_by: 1.5 }}px;
    }
    
    .sig-grid {
      /* Mobile: 2 cột bằng nhau */
      grid-template-columns: repeat(2, 1fr); 
      /* Giảm khoảng cách trên mobile cho thoáng */
      gap: 10px; 
    }
  }
</style>

<div class="sig-section-{{ section.id }}">
  <div class="sig-container">
    
    {% if section.settings.heading != blank %}
      <h2 class="sig-heading">{{ section.settings.heading }}</h2>
    {% endif %}

    <div class="sig-grid">
      {% for block in section.blocks %}
        <div class="sig-item-wrapper" {{ block.shopify_attributes }}>
          {% if block.settings.link != blank %}
            <a href="{{ block.settings.link }}" class="sig-item">
          {% else %}
            <div class="sig-item">
          {% endif %}

            {% if block.settings.image != blank %}
              <img src="{{ block.settings.image | image_url: width: 600 }}" 
                   alt="{{ block.settings.image.alt | escape }}" 
                   loading="lazy" 
                   width="{{ block.settings.image.width }}" 
                   height="{{ block.settings.image.height }}">
            {% else %}
              {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
            {% endif %}

          {% if block.settings.link != blank %}
            </a>
          {% else %}
            </div>
          {% endif %}
        </div>
      {% endfor %}
    </div>

  </div>
</div>

{% schema %}
{
  "name": "Simple Image Grid (4x2)",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Padding Top",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 0
    },
    {
      "type": "range",
      "id": "gap",
      "min": 0,
      "max": 50,
      "step": 5,
      "unit": "px",
      "label": "Gap between images",
      "default": 20
    },
    {
      "type": "range",
      "id": "border_radius",
      "min": 0,
      "max": 20,
      "step": 1,
      "unit": "px",
      "label": "Image Corner Radius",
      "default": 0
    },
    {
      "type": "select",
      "id": "aspect_ratio",
      "label": "Image Aspect Ratio",
      "options": [
        { "value": "auto", "label": "Original Size" },
        { "value": "1 / 1", "label": "Square (1:1)" },
        { "value": "4 / 5", "label": "Portrait (4:5)" },
        { "value": "16 / 9", "label": "Landscape (16:9)" }
      ],
      "default": "1 / 1",
      "info": "Forces all images to be the same shape."
    }
  ],
  "blocks": [
    {
      "type": "image",
      "name": "Image",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link (Optional)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Simple Image Grid (4x2)",
      "blocks": [
        { "type": "image" },
        { "type": "image" },
        { "type": "image" },
        { "type": "image" }
      ]
    }
  ]
}
{% endschema %}