{% comment %}
  Section: Smart Newsletter Popup
  Features: Split Layout, Delay, Frequency Cap, Advanced Display Logic (Template/Handle targeting)
{% endcomment %}

{%- assign show_popup = false -%}

{%- if section.settings.display_scope == 'all' -%}
  {%- assign show_popup = true -%}
{%- else -%}
  {%- if section.settings.show_on_home and template.name == 'index' -%}
    {%- assign show_popup = true -%}
  {%- endif -%}
  {%- if section.settings.show_on_collection and template.name == 'collection' -%}
    {%- assign show_popup = true -%}
  {%- endif -%}
  {%- if section.settings.show_on_product and template.name == 'product' -%}
    {%- assign show_popup = true -%}
  {%- endif -%}
  {%- if section.settings.show_on_blog and template.name == 'article' or template.name == 'blog' -%}
    {%- assign show_popup = true -%}
  {%- endif -%}
  {%- if section.settings.show_on_cart and template.name == 'cart' -%}
    {%- assign show_popup = true -%}
  {%- endif -%}

  {%- if section.settings.target_handles != blank -%}
    {%- assign handles = section.settings.target_handles | split: ',' -%}
    {%- for handle in handles -%}
      {%- assign clean_handle = handle | strip -%}
      {%- if clean_handle == collection.template_suffix
          or clean_handle == product.template_suffix
          or clean_handle == page.template_suffix -%}
        {%- assign show_popup = true -%}
        {%- break -%}
      {%- endif -%}
    {%- endfor -%}
  {%- endif -%}
{%- endif -%}

{%- if show_popup and section.settings.enable_popup -%}

  <div id="newsletter-popup-{{ section.id }}" class="popup-overlay" style="display: none;">
    <div class="popup-container">
      
      <button class="popup-close" aria-label="Close">&times;</button>

      <div class="popup-image">
        {%- if section.settings.image != blank -%}
          <img 
            src="{{ section.settings.image | image_url: width: 800 }}" 
            alt="{{ section.settings.heading | escape }}"
            loading="lazy"
            width="400" height="500"
          >
        {%- else -%}
          {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
        {%- endif -%}
      </div>

      <div class="popup-content" style="background-color: {{ section.settings.bg_color }};">
        <div class="popup-text-wrapper">
          {%- if section.settings.subheading != blank -%}
            <p class="popup-subheading" style="color: {{ section.settings.text_color }};">{{ section.settings.subheading }}</p>
          {%- endif -%}
          
          {%- if section.settings.heading != blank -%}
            <h2 class="popup-heading" style="color: {{ section.settings.text_color }};">{{ section.settings.heading }}</h2>
          {%- endif -%}

          {%- if section.settings.description != blank -%}
            <div class="popup-desc" style="color: {{ section.settings.text_color }}; opacity: 0.8;">
              {{ section.settings.description }}
            </div>
          {%- endif -%}

          {% form 'customer', class: 'popup-form' %}
            <input type="hidden" name="contact[tags]" value="newsletter, popup, home-decor">
            {%- if form.posted_successfully? -%}
              <p class="form-success" style="color: {{ section.settings.btn_bg }}; font-weight: bold;">
                "Thanks for subscribing!"
              </p>
              <script>
                localStorage.setItem('popupSubscribed', 'true');
                setTimeout(function(){ document.getElementById('newsletter-popup-{{ section.id }}').style.display = 'none'; }, 2000);
              </script>
            {%- else -%}
              <div class="input-group">
                <input type="email" name="contact[email]" class="popup-input" value="{{ form.email }}" placeholder="Your email address" required>
                <button type="submit" class="popup-submit" style="background-color: {{ section.settings.btn_bg }}; color: {{ section.settings.btn_text }};">
                  {{ section.settings.btn_label }}
                </button>
              </div>
              {%- if form.errors -%}
                <div class="form-error">{{ form.errors | default_errors }}</div>
              {%- endif -%}
            {%- endif -%}
          {% endform %}
          
          <p class="popup-disclaimer" style="color: {{ section.settings.text_color }}; opacity: 0.6;">
            {{ section.settings.disclaimer }}
          </p>
        </div>
      </div>
    </div>
  </div>

  <style>

    /* CSS Styles (Giữ nguyên cấu trúc cũ, tối ưu một chút) */
    .popup-overlay {
      position: fixed; top: 0; left: 0; width: 100%; height: 100%;
      background: rgba(0, 0, 0, {{ section.settings.overlay_opacity | divided_by: 100.0 }});
      z-index: 99999; display: flex; justify-content: center; align-items: center;
      opacity: 0; visibility: hidden; transition: opacity 0.4s ease, visibility 0.4s ease;
    }
    .popup-overlay.is-visible { opacity: 1; visibility: visible; }

    .popup-container {
      background: #fff; width: 90%; max-width: 850px; display: flex;
      position: relative; border-radius: 8px; overflow: hidden;
      box-shadow: 0 20px 40px rgba(0,0,0,0.2);
      transform: translateY(20px); transition: transform 0.4s ease;
      min-height: 0px !important;
    }
    .popup-overlay.is-visible .popup-container { transform: translateY(0); }

    .popup-close {
      position: absolute; top: 10px; padding: 0; background: none; border: none;
      font-size: 30px; line-height: 1; cursor: pointer; z-index: 10; color: #333; opacity: 0.6;
      width: 40px !important; height: 40px !important;
      min-width: 0px !important; min-height: 0px !important;
      right: 0; top: 0;
    }
    {% comment %} .popup-close:hover { opacity: 1; } {% endcomment %}
    .popup-close:before { display: none;}
    .popup-image { width: 50%; display: none; }
    @media (min-width: 769px) { .popup-image { display: block; } }
    .popup-image img, .popup-image svg { width: 100%; height: 100%; object-fit: cover; display: block; }

    .popup-content { width: 100%; padding: 10px; display: flex; flex-direction: column; justify-content: center; text-align: center; }
    @media (min-width: 769px) { .popup-content { width: 50%; padding: 40px 40px 0px 40px; text-align: left; } .popup-image { display: block; } }

    .popup-subheading { text-transform: uppercase; letter-spacing: 1px; font-size: 0.85rem; font-weight: bold; margin-bottom: 10px; }
    .popup-heading { font-size: 2rem; margin: 0 0 15px 0; line-height: 1.2; font-weight: 700; }
    .popup-desc { margin-bottom: 25px; font-size: 1rem; line-height: 1.5; }

    .popup-form { width: 100%; }
    .input-group { display: flex; flex-direction: column; gap: 10px; }
    .popup-input { padding: 12px 15px; border: 1px solid #ddd; border-radius: 4px; width: 100%; }
    .popup-submit { padding: 12px 25px; border: none; border-radius: 4px; font-weight: bold; cursor: pointer; text-transform: uppercase; border-radius: 10px;}
    .popup-submit:before { display: none;}
    .popup-disclaimer { font-size: 0.75rem; margin-top: 15px; font-style: italic; }
    .placeholder-svg { background: #eee; width: 100%; height: 100%; }
  </style>

  <script>
    document.addEventListener("DOMContentLoaded", function() {
      const sectionId = "{{ section.id }}";
      const popup = document.getElementById(`newsletter-popup-${sectionId}`);
      if(!popup) return; // Nếu liquid không render popup thì thoát script

      const closeBtn = popup.querySelector('.popup-close');
      const delay = {{ section.settings.delay }} * 1000;
      const daysToExpire = {{ section.settings.frequency }};
      const storageKey = 'shopifyPopupClosed';

      function shouldShowPopup() {
        if (localStorage.getItem('popupSubscribed') === 'true') return false;
        const lastClosed = localStorage.getItem(storageKey);
        if (lastClosed) {
          const now = new Date().getTime();
          const daysSince = (now - lastClosed) / (1000 * 60 * 60 * 24);
          if (daysSince < daysToExpire) return false;
        }
        return true;
      }

      function showPopup() {
        if (shouldShowPopup()) {
          popup.style.display = 'flex';
          setTimeout(() => { popup.classList.add('is-visible'); }, 10);
        }
      }

      function closePopup() {
        popup.classList.remove('is-visible');
        setTimeout(() => { popup.style.display = 'none'; }, 400);
        localStorage.setItem(storageKey, new Date().getTime());
      }

      setTimeout(showPopup, delay);
      closeBtn.addEventListener('click', closePopup);
      popup.addEventListener('click', function(e) { if (e.target === popup) closePopup(); });
    });
  </script>

{%- endif -%}

{% schema %}
{
  "name": "Popup with home-decor tag",
  "settings": [
    { "type": "header", "content": "Bật/Tắt & Cấu hình" },
    { "type": "checkbox", "id": "enable_popup", "label": "Bật Popup", "default": true },
    { "type": "range", "id": "delay", "min": 1, "max": 60, "step": 1, "label": "Delay (giây)", "default": 5 },
    { "type": "range", "id": "frequency", "min": 0, "max": 30, "step": 1, "label": "Hiện lại sau (ngày)", "default": 7 },
    
    { "type": "header", "content": "🎯 Nơi hiển thị (Display Logic)" },
    {
      "type": "select",
      "id": "display_scope",
      "label": "Phạm vi hiển thị",
      "options": [
        { "value": "all", "label": "Tất cả các trang" },
        { "value": "specific", "label": "Chỉ các trang được chọn bên dưới" }
      ],
      "default": "all"
    },
    { "type": "checkbox", "id": "show_on_home", "label": "Trang chủ (Home)", "default": true },
    { "type": "checkbox", "id": "show_on_collection", "label": "Tất cả Collection", "default": false },
    { "type": "checkbox", "id": "show_on_product", "label": "Tất cả Sản phẩm", "default": false },
    { "type": "checkbox", "id": "show_on_blog", "label": "Tất cả Blog/Bài viết", "default": false },
    { "type": "checkbox", "id": "show_on_cart", "label": "Giỏ hàng (Cart)", "default": false },
    {
      "type": "textarea",
      "id": "target_handles",
      "label": "Danh sách trang cụ thể (Handles)",
      "info": "Nhập template_suffix của trang, cách nhau bằng dấu phẩy. Ví dụ: 'about-us, summer-sale, ao-thun-nam'. Để trống nếu không dùng."
    },

    { "type": "header", "content": "Hình ảnh Hero" },
    { "type": "image_picker", "id": "image", "label": "Hình ảnh" },
    
    { "type": "header", "content": "Nội dung" },
    { "type": "text", "id": "subheading", "label": "Subheading", "default": "Join Us" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Get 10% Off" },
    { "type": "textarea", "id": "description", "label": "Mô tả", "default": "Sign up for exclusive offers." },
    { "type": "text", "id": "btn_label", "label": "Nút bấm", "default": "Subscribe" },
    { "type": "text", "id": "disclaimer", "label": "Ghi chú", "default": "No spam, unsubscribe anytime." },
    
    { "type": "header", "content": "Màu sắc" },
    { "type": "color", "id": "bg_color", "label": "Màu nền", "default": "#ffffff" },
    { "type": "color", "id": "text_color", "label": "Màu chữ", "default": "#333333" },
    { "type": "color", "id": "btn_bg", "label": "Màu nút", "default": "#000000" },
    { "type": "color", "id": "btn_text", "label": "Màu chữ nút", "default": "#ffffff" },
    { "type": "range", "id": "overlay_opacity", "min": 0, "max": 90, "step": 10, "unit": "%", "label": "Độ tối nền", "default": 50 }
  ],
  "presets": [ { "name": "Popup with home-decor tag" } ]
}
{% endschema %}