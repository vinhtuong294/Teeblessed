{% assign image_fit = section.settings.image_fit | default: 'cover' %}
{% assign transition_effect = section.settings.transition_effect | default: 'slide' %}
<div
  class="
    m6fr
    mobile-text-center
    slider-fraction
    image-fit-{{ image_fit }}
    transition-{{ transition_effect }}
    {{ section.settings.width }}
    {% if section.settings.width == 'wide' %}wide-transparent{% endif %}
    {% if section.settings.height != 'adapt' %}size-{{ section.settings.height }}{% endif %}
    {% if section.settings.height_mobile != 'adapt' %}size-{{ section.settings.height_mobile }}-mobile{% else %}size-xs-mobile{% endif %}
    {% unless section.settings.enable_controls %}no-controls{% endunless %}
  "
  {% if section.settings.autoplay %}
    data-autoplay="{{ section.settings.autoplay_seconds | times: 1000 }}"
  {% endif %}
  data-transition-effect="{{ transition_effect }}"
  data-active-content="palette-{{ section.blocks[0].settings.color_palette }}"
  {% if settings.enable_animations %}
    data-sal="fade" data-sal-duration="500"
  {% endif %}
>
  {% liquid
    assign ref_img = section.blocks.first.settings.image
    if ref_img == blank and section.blocks.first.settings.video
      assign ref_img = section.blocks.first.settings.video
    endif
    if section.settings.enable_custom_height or section.settings.height == 'xl'
      assign padding_bottom = 0
    else
      if section.settings.height == 'adapt'
        assign padding_bottom = 1 | divided_by: ref_img.aspect_ratio | times: 100 | round: 2
      else
        assign aspect_ratio = section.settings.height | split: '/'
        assign temp = aspect_ratio[0] | append: '.0'
        assign ratio = aspect_ratio[1] | divided_by: temp | round: 2
        assign padding_bottom = ratio | times: 100 | round: 2
      endif
    endif
    if section.settings.height_mobile == 'adapt'
      if section.blocks.first.settings.image_mobile
        assign ref_img = section.blocks.first.settings.image_mobile
      endif
      assign padding_bottom_mobile = 1 | divided_by: ref_img.aspect_ratio | times: 100 | round: 2
    else
      assign aspect_ratio = section.settings.height_mobile | split: '/'
      assign temp = aspect_ratio[0] | append: '.0'
      assign ratio = aspect_ratio[1] | divided_by: temp | round: 2
      assign padding_bottom_mobile = ratio | times: 100 | round: 2
    endif
  %}

  {%- for block in section.blocks -%}
    {%- liquid
      capture current
        cycle 1, 2
      endcapture
      assign overlay = false
      if block.settings.color_palette.id != settings.default_color_scheme.id
        assign overlay = true
      endif
      assign banner_link = block.settings.first_link_url
      if banner_link == blank
        assign banner_link = block.settings.second_link_url
      endif
    -%}
    {% if block.settings.image_mobile %}
      {% capture mobile_image %}
        <picture class="mobile-only">
          <a href="{{banner_link}}"><span class="img-overlay" style="--overlay_opacity:{{ block.settings.overlay_opacity | divided_by: 100.0 }}"></span></a>
          {% capture srcset %}
            {% render 'image-srcset', image: block.settings.image_mobile, max_width: 940 %}
          {% endcapture %}
          {% capture sizes %}
            (min-width: 768px) 0,
            100vw
          {% endcapture %}
          {% assign alt = block.settings.image_mobile.alt | default: block.settings.title | escape %}
          {%- if forloop.first and section.index == 1 -%}
            {%- if image_fit == 'contain' -%}
              {{ block.settings.image_mobile | image_url: width: 700 | image_tag: srcset: srcset, sizes: sizes, preload: true, alt: alt }}
            {%- else -%}
              {{ block.settings.image_mobile | image_url: width: 700, height: 530, crop: 'center' | image_tag: srcset: srcset, sizes: sizes, preload: true, alt: alt }}
            {%- endif -%}
          {%- else -%}
            {%- if image_fit == 'contain' -%}
              {{ block.settings.image_mobile | image_url: width: 700 | image_tag: srcset: srcset, sizes: sizes, loading: 'lazy', alt: alt }}
            {%- else -%}
              {{ block.settings.image_mobile | image_url: width: 700, height: 530, crop: 'center' | image_tag: srcset: srcset, sizes: sizes, loading: 'lazy', alt: alt }}
            {%- endif -%}
          {%- endif -%}
        </picture>
      {% endcapture %}
    {% endif %}
    <article id="bannerhihi"
      class="
        palette-{{ block.settings.color_palette }}
        block-{{ block.id }}
        {% unless block.settings.layout == 'background' %}
          width-{{ block.settings.image_width }} w-aside
          {% unless overlay %}
            has-border
          {% endunless %}
        {% endunless %}
        {% if block.settings.layout == 'right' %}inv{% endif %}
        module-color-palette
      "
      data-slide-index="{{ forloop.index }}"
      data-color-palette="{{ block.settings.color_palette }}"
      {{ block.shopify_attributes }}
      style="
        {% if section.settings.height != 'xl' %}--aspect: {{ padding_bottom }};{% endif %}
        {% if section.settings.height_mobile != 'l' %}--aspect_m: {{ padding_bottom_mobile }};{% endif %}
        {% if block.settings.enable_custom_font_styling %}
         --main_fz:{{ block.settings.font_size }};
          font-size:var(--main_fz);
        {% endif %}
        {% unless block.settings.layout == 'background' %}--width: {{ block.settings.image_width }}%;{% endunless %}
        --align_text: {{ block.settings.text_position | split: ' ' | first }};
        --justify_text: {{ block.settings.text_position | split: ' ' | last }};
        --gutter: {{ settings.gutter }};
      "
    >
      <style>
        @media (min-width: 1500px) {
          #bannerhihi { 
            font-size: 25px !important;
          }
          #shopify-section-template--19386574471225__6ed76557-f01f-4c16-be59-921274d42b0b h1 {
          {% comment %} text-align: left;     {% endcomment %}
           font-size: 60px;
          } 
        }
      </style>
      <figure>
        {%- if block.settings.video -%}
          {% if block.settings.show_play_button -%}
            <a
              href="./"
              {% if block.settings.image_mobile %}
                class="mobile-hide"
              {% endif %}
              aria-label="{{ block.settings.title | escape | default: "Play video" }}"
            >
          {%- endif %}
          <picture
            {% if block.settings.image_mobile %}
              class="mobile-hide"
            {% endif %}
          >
            <span
              class="img-overlay"
              style="--overlay_opacity:{{ block.settings.overlay_opacity | divided_by: 100.0 }}"
            ></span>
            {%- liquid
              assign source = block.settings.video.sources | where: 'height', 1080 | where: 'format', 'mp4' | first
              if source == null
                assign source = block.settings.video.sources | where: 'format', 'mp4' | first
              endif
              if source == null
                assign source = block.settings.video.sources | where: 'format', 'mov' | first
              endif
              if source == null
                assign source = block.settings.video.sources.first
              endif
            -%}
            <video
              class="lazy next-video"
              {% if block.settings.show_play_button %}
                {%- if block.settings.video_mute %} muted{% endif -%}
              {% else %}
                autoplay muted
              {% endif %}
              loop
              playsinline
              poster="{{ block.settings.video.preview_image | image_url }}"
            >
              <source data-src="{{ source.url }}" type="video/mp4">
            </video>
            {% if block.settings.show_play_button %}<i aria-hidden="true" class="icon-play"></i>{% endif %}
          </picture>
          {% if block.settings.show_play_button %}</a>{% endif %}
          {{ mobile_image }}
        {%- elsif block.settings.image -%}
          <picture
            {% if block.settings.image_mobile %}
              class="mobile-hide"
            {% endif %}
          >
            <a href="{{banner_link}}"><span
              class="img-overlay"
              style="--overlay_opacity:{{ block.settings.overlay_opacity | divided_by: 100.0 }}"
            ></span></a>
            {% capture srcset %}
              {% render 'image-srcset', image: block.settings.image, max_width: 2900 %}
            {% endcapture %}
            {% capture sizes %}
              (min-width: 1300px)
              {% if section.settings.width == 'boxed' or settings.width < 2000 %}
                {% if block.settings.layout == 'background' %}{{ settings.width }}px{% else %}calc({{ settings.width }}px / 2),{% endif %}
              {% else %}
                {% if block.settings.layout == 'background' %}100vw{% else %}calc(100vw / 2),{% endif %}
              {% endif %}
              {% if block.settings.image_mobile %}0{% else %}100vw{% endif %}
            {% endcapture %}
            {% assign alt = block.settings.image.alt | default: block.settings.title | escape %}
            {%- if forloop.first -%}
              {%- if image_fit == 'contain' -%}
                {{
                  block.settings.image
                  | image_url: width: 700
                  | image_tag: srcset: srcset, sizes: sizes, preload: true, alt: alt
                }}
              {%- else -%}
                {{
                  block.settings.image
                  | image_url: width: 700, height: 530, crop: 'center'
                  | image_tag: srcset: srcset, sizes: sizes, preload: true, alt: alt
                }}
              {%- endif -%}
            {%- else -%}
              {%- if image_fit == 'contain' -%}
                {{
                  block.settings.image
                  | image_url: width: 700
                  | image_tag: srcset: srcset, sizes: sizes, loading: 'lazy', alt: alt
                }}
              {%- else -%}
                {{
                  block.settings.image
                  | image_url: width: 700, height: 530, crop: 'center'
                  | image_tag: srcset: srcset, sizes: sizes, loading: 'lazy', alt: alt
                }}
              {%- endif -%}
            {%- endif -%}
          </picture>
          {{ mobile_image }}
        {% else %}
          <picture>
            <span
              class="img-overlay"
              style="--overlay_opacity:{{ block.settings.overlay_opacity | divided_by: 100.0 }}"
            ></span>
            {{ 'lifestyle-' | append: current | placeholder_svg_tag: 'placeholder-svg' }}
          </picture>
        {% endif %}
        {%- if settings.banners_clickable and block.settings.first_link_url != blank -%}
          <a
            class="link-overlay"
            href="{{ block.settings.first_link_url }}"
            aria-label="{{ block.settings.title | escape | default: block.settings.image.alt | default: "Image banner" }}"
          ></a>
        {%- endif -%}
      </figure>
      <div
        id="div-contains-banner-btn"
        class="text-{{ block.settings.text_position | split: ' ' | last }} title-styling"
        style="{% if block.settings.layout == 'background' %}--width: {{ block.settings.max_width }}px{% endif %};"
      >
        {%- if block.settings.title != blank -%}
          <div
            class="
              heading
              {% if block.settings.title_underline_style != 'none' %}
                title-underline-none
                {% if block.settings.title_underline_style contains 'accent' %}
                  title-underline-accent
                {% elsif block.settings.title_underline_style contains 'gradient' %}
                  title-underline-gradient
                {% endif %}
                {% if block.settings.title_underline_style contains 'secondary_font' %}
                  title-underline-secondary-font
                {% endif %}
              {% endif %}
            "
          >
            {{ block.settings.title }}
          </div>
        {%- endif -%}
        {%- if block.settings.text != empty -%}
          <div id="banner-text-pc">
            {{ block.settings.text }}
          </div>
        {%- endif -%}
        {%- liquid
          assign first_link = false
          assign first_show_link = false
          assign second_link = false
          assign second_show_link = false

          if block.settings.show_first_link and block.settings.first_link_text != empty and block.settings.first_link_url != blank
            assign first_link = true
            assign first_button_color = block.settings.first_button_style | split: ' ' | first
            assign first_button_style = block.settings.first_button_style | split: ' ' | last
            if first_button_style == 'link'
              assign first_show_link = true
            endif
          endif
          if block.settings.show_second_link and block.settings.second_link_text != empty and block.settings.second_link_url != blank
            assign second_link = true
            assign second_button_color = block.settings.second_button_style | split: ' ' | first
            assign second_button_style = block.settings.second_button_style | split: ' ' | last
            if second_button_style == 'link'
              assign second_show_link = true
            endif
          endif
        -%}
        {%- if first_link or second_link -%}
          <p id="banner-btn"
            class="link-btn"
            style=""
          >
            {% if first_link %}
              <a
                href="{{ block.settings.first_link_url }}"
                class="overlay-{{ first_button_color }} {% if first_show_link %} strong inline{% else %} {{ first_button_style }}{% endif %}"
              >
                {% if block.settings.icon_1 -%}
                  {{-
                    block.settings.icon_1
                    | image_url: width: block.settings.icon_width_1
                    | image_tag: width: block.settings.icon_width_1
                  -}}
                {%- endif %}
                <span
                  {% if first_show_link %}
                    class="link-underline"
                  {% endif %}
                >
                  {{- block.settings.first_link_text -}}
                  {% if first_show_link %}&nbsp;<i aria-hidden="true" class="icon-arrow-right"></i>{% endif %}
                </span>
              </a>
            {% endif %}
            {%- if second_link -%}
              <a
                href="{{ block.settings.second_link_url }}"
                class="overlay-{{ second_button_color }} {% if second_show_link %} strong inline{% else %} {{ second_button_style }}{% endif %}"
              >
                {% if block.settings.icon_2 -%}
                  {{-
                    block.settings.icon_2
                    | image_url: width: block.settings.icon_width_2
                    | image_tag: width: block.settings.icon_width_2
                  -}}
                {%- endif %}
                <span
                  {% if second_show_link %}
                    class="link-underline"
                  {% endif %}
                >
                  {{- block.settings.second_link_text -}}
                  {% if second_show_link %}&nbsp;<i aria-hidden="true" class="icon-arrow-right"></i>{% endif %}
                </span>
              </a>
            {%- endif -%}
          </p>
          
        {%- endif -%}
        {%- if settings.banners_clickable and block.settings.first_link_url != blank -%}
          <a
            class="link-overlay"
            href="{{ block.settings.first_link_url }}"
            aria-label="{{ block.settings.title | escape | default: block.settings.image.alt | default: "Image banner" }}"
          ></a>
        {%- endif -%}
      </div>
      <style>
        #shopify-section-{{ section.id }} { z-index: {{ section.settings.fix_zindex }}!important; }
        {%- if section.settings.width == 'wide' -%}
        #shopify-section-{{ section.id }} .m6fr article.block-{{ block.id }}:before { opacity: {{ block.settings.background_overlay_opacity | divided_by: 100.0 }}; }
        {%- endif -%}
        {% comment %} @media (max-width: 1000px) {
        #div-contains-banner-btn {
        display: none;
        } 
        }{% endcomment %}
        #shopify-section-{{ section.id }} article.block-{{ block.id }} #div-contains-banner-btn {
          position: static !important;
        }
        #shopify-section-{{ section.id }} .m6fr .swiper-custom-bullets {
          display: none !important;
        }
        #shopify-section-{{ section.id }} article.block-{{ block.id }}.w-aside #banner-btn {
          position: static !important;
          display: flex !important;
          align-items: center;
          justify-content: center;
          width: auto !important;
          height: auto !important;
          margin: 10px 0 0 !important;
          padding: 0 !important;
          pointer-events: auto;
        }
        #shopify-section-{{ section.id }} article.block-{{ block.id }}:not(.w-aside) #banner-btn {
          position: absolute !important;
          z-index: 12;
          top: var(--rpp);
          right: var(--rpp);
          bottom: var(--rpp);
          left: var(--rpp);
          width: auto !important;
          height: auto !important;
          margin: 0 !important;
          pointer-events: none;
          align-items: {{ block.settings.button_mobile_position | default: 'end' | split: ' ' | first }};
          justify-content: {{ block.settings.button_mobile_position | default: 'end' | split: ' ' | last }};
        }
        #shopify-section-{{ section.id }} article.block-{{ block.id }}:not(.w-aside) #banner-btn a {
          width: {{ section.settings.mobile_button_width }}px !important;
          min-width: {{ section.settings.mobile_button_width }}px;
          height: {{ section.settings.mobile_button_height }}px;
          min-height: {{ section.settings.mobile_button_height }}px;
          padding: 0 18px;
          margin-right: 0;
          flex-shrink: 0;
          pointer-events: auto;
          transform: translate({{ block.settings.button_mobile_offset_x | default: 0 }}px, {{ block.settings.button_mobile_offset_y | default: 0 }}px);
          color: {{ section.settings.mobile_button_text_color }} !important;
          font-size: {{ section.settings.mobile_button_font_size }}px;
          --button_height: {{ section.settings.mobile_button_height }}px;
          --theme_btn_text: {{ section.settings.mobile_button_text_color }};
          --theme_bg_btn: {{ section.settings.mobile_button_background_color }};
          --theme_bg_btn_dark: {{ section.settings.mobile_button_background_color }};
        }
        #shopify-section-{{ section.id }} article.block-{{ block.id }}:not(.w-aside) #banner-btn a:before {
          border-color: {{ section.settings.mobile_button_background_color }} !important;
          background: {{ section.settings.mobile_button_background_color }} !important;
        }
        @media (max-width: 1199px) {
        #shopify-section-{{ section.id }} article.block-{{ block.id }} {
          min-height: var(--mh) !important;
        }
        #shopify-section-{{ section.id }} article.block-{{ block.id }} > figure:not([class*="flexible"]) {
          bottom: 0 !important;
        }
        #shopify-section-{{ section.id }} article.block-{{ block.id }} #div-contains-banner-btn {
          position: static !important;
          z-index: 13;
          width: 100% !important;
          max-width: none !important;
          margin: 0 !important;
          padding: 0 !important;
        }
        #shopify-section-{{ section.id }} article.block-{{ block.id }}:not(.w-aside) #banner-btn {
          position: absolute !important;
          top: auto !important;
          right: 0 !important;
          bottom: 12px !important;
          left: 0 !important;
          display: flex !important;
          align-items: center;
          justify-content: center;
          width: 100% !important;
          height: {{ section.settings.mobile_button_height }}px !important;
          margin: 0 !important;
          padding: 0 !important;
          pointer-events: auto;
        }
        #shopify-section-{{ section.id }} article.block-{{ block.id }}:not(.w-aside) #banner-btn a {
          display: inline-flex;
          align-items: center;
          justify-content: center;
        }
        }
        @media (min-width: 1200px) {
        #shopify-section-{{ section.id }} article.block-{{ block.id }}:not(.w-aside) #banner-btn {
          align-items: {{ block.settings.button_desktop_position | default: 'end' | split: ' ' | first }};
          justify-content: {{ block.settings.button_desktop_position | default: 'end' | split: ' ' | last }};
          }
        #shopify-section-{{ section.id }} article.block-{{ block.id }}:not(.w-aside) #banner-btn a {
          width: {{ section.settings.desktop_button_width }}px !important;
          min-width: {{ section.settings.desktop_button_width }}px;
          height: {{ section.settings.desktop_button_height }}px;
          min-height: {{ section.settings.desktop_button_height }}px;
          padding: 0 22px;
          margin-right: 0;
          flex-shrink: 0;
          transform: translate({{ block.settings.button_desktop_offset_x | default: 0 }}px, {{ block.settings.button_desktop_offset_y | default: 0 }}px);
          color: {{ section.settings.desktop_button_text_color }} !important;
          font-size: {{ section.settings.desktop_button_font_size }}px;
          --button_height: {{ section.settings.desktop_button_height }}px;
          --theme_btn_text: {{ section.settings.desktop_button_text_color }};
          --theme_bg_btn: {{ section.settings.desktop_button_background_color }};
          --theme_bg_btn_dark: {{ section.settings.desktop_button_background_color }};
          }
        #shopify-section-{{ section.id }} article.block-{{ block.id }}:not(.w-aside) #banner-btn a:before {
          border-color: {{ section.settings.desktop_button_background_color }} !important;
          background: {{ section.settings.desktop_button_background_color }} !important;
          }
        }
        {% unless section.settings.show_links_mobile %}
        @media (max-width: 1000px)
        {
        #shopify-section-{{ section.id }} article.block-{{ block.id }}:not(.w-aside) #banner-btn {
        display: none;
        }
        }
        {% endunless %}
      </style>
    </article>
  {%- endfor -%}
</div>

<style>
  {%- if section.settings.width == 'wide' -%}
  html.no-js .shopify-section-header:has(#header-outer.transparent):has(+ #content > div:first-child[id$="{{ section.id }}"] > .wide-transparent.slider-fraction) {
    --top_main_bg: var(--{{ section.blocks.first.settings.color_palette }}_bg) !important;
    --top_main_fg: var(--{{ section.blocks.first.settings.color_palette | replace: '_gradient', '' }}_fg) !important;
    --menu_fg: var(--top_main_fg) !important;
  }
  {% endif %}

  #shopify-section-{{ section.id }} .m6fr.no-controls .play-pause { display: none; }
  #shopify-section-{{ section.id }} .m6fr.transition-fade.s4wi .swiper-outer {
    overflow: hidden;
  }
  #shopify-section-{{ section.id }} .m6fr.transition-fade.s4wi .swiper-wrapper {
    display: block !important;
    position: relative;
    transform: none !important;
    transition-property: none !important;
  }
  #shopify-section-{{ section.id }} .m6fr.transition-fade.s4wi .swiper-slide {
    position: absolute !important;
    inset: 0;
    width: 100% !important;
    opacity: 0 !important;
    pointer-events: none;
    transform: none !important;
    transition: opacity 700ms ease-in-out !important;
  }
  #shopify-section-{{ section.id }} .m6fr.transition-fade.s4wi .swiper-slide-active {
    position: relative !important;
    z-index: 3;
    opacity: 1 !important;
    pointer-events: auto;
  }
  #shopify-section-{{ section.id }} .m6fr.transition-fade.s4wi .swiper-slide:not(.swiper-slide-active) #banner-btn {
    visibility: hidden !important;
    opacity: 0 !important;
  }
  #shopify-section-{{ section.id }} .m6fr.transition-fade.s4wi .swiper-slide-active #banner-btn {
    visibility: visible !important;
    opacity: 1 !important;
  }
  @media (prefers-reduced-motion: reduce) {
    #shopify-section-{{ section.id }} .m6fr.transition-fade.s4wi .swiper-slide {
      transition: none !important;
    }
  }
  #root #shopify-section-{{ section.id }} .m6fr.image-fit-contain article > figure picture,
  #root #shopify-section-{{ section.id }} .m6fr.image-fit-contain article > figure img,
  #root #shopify-section-{{ section.id }} .m6fr.image-fit-contain article > figure video,
  #root #shopify-section-{{ section.id }} .m6fr.image-fit-contain article > figure svg,
  #root #shopify-section-{{ section.id }} .m6fr.image-fit-contain article > figure iframe {
    min-width: 0 !important;
    width: 100% !important;
    max-width: none;
    height: 100% !important;
    object-fit: contain !important;
    object-position: center center !important;
  }
  #shopify-section-{{ section.id }} .m6fr.s4wi .swiper-button-nav {
    display: block !important;
    visibility: visible !important;
    opacity: 1 !important;
    color: #20262d;
    --ar_bg: #ffffff;
    --ar_op: 1;
    --button_height: 48px;
    width: 48px !important;
    min-width: 48px !important;
    transform: none !important;
    transition: none !important;
    scale: 1 !important;
    -webkit-tap-highlight-color: transparent;
    touch-action: manipulation;
  }
  #shopify-section-{{ section.id }} .m6fr.s4wi .swiper-button-nav:hover,
  #shopify-section-{{ section.id }} .m6fr.s4wi .swiper-button-nav:focus,
  #shopify-section-{{ section.id }} .m6fr.s4wi .swiper-button-nav:active {
    width: 48px !important;
    min-width: 48px !important;
    transform: none !important;
    transition: none !important;
    scale: 1 !important;
  }
  #shopify-section-{{ section.id }} .m6fr.s4wi .swiper-button-nav:before {
    display: block;
    position: absolute;
    left: 50%;
    right: auto;
    top: 50%;
    z-index: 3;
    width: 21px;
    height: 24px;
    margin: 0;
    border: 0;
    background-repeat: no-repeat;
    background-position: center;
