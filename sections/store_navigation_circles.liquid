{% comment %}
  Section: Story Navigation
  Description: A horizontal scrollable list of circular links, similar to Instagram Stories.
{% endcomment %}

<style>
  /* --- VISIBILITY LOGIC --- */
  /* Default: Show everywhere */
  #shopify-section-{{ section.id }} {
    display: block;
  }

  /* Logic for 'Mobile Only' */
  {% if section.settings.visibility == 'mobile' %}
    @media screen and (min-width: 769px) {
      #shopify-section-{{ section.id }} {
        display: none !important;
      }
    }
  {% endif %}

  /* Logic for 'Desktop Only' */
  {% if section.settings.visibility == 'desktop' %}
    @media screen and (max-width: 768px) {
      #shopify-section-{{ section.id }} {
        display: none !important;
      }
    }
  {% endif %}

  /* --- LAYOUT STYLES --- */
  .story-nav-container {
    width: 100%;
    overflow-x: auto;
    white-space: nowrap;
    padding: {{ section.settings.padding_top }}px 10px {{ section.settings.padding_bottom }}px;
    background-color: {{ section.settings.background_color }};
    -webkit-overflow-scrolling: touch;
    /* Hide Scrollbar */
    scrollbar-width: none; /* Firefox */
    -ms-overflow-style: none; /* IE/Edge */
  }
  
  .story-nav-container::-webkit-scrollbar {
    display: none; /* Chrome/Safari */
  }

  .nav-list {
    display: flex;
    justify-content: {{ section.settings.alignment }}; /* Allow centering if few items */
    gap: 20px;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .nav-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-decoration: none;
    cursor: pointer;
    width: 80px;
    flex-shrink: 0;
  }

  .img-wrapper {
    width: {{ section.settings.image_size }}px;
    height: {{ section.settings.image_size }}px;
    border-radius: 50%;
    overflow: hidden;
    margin-bottom: 8px;
    border: 2px solid {{ section.settings.border_color }};
    padding: 2px; /* Gap between image and border */
    transition: transform 0.2s ease;
  }

  /* Highlight/Active State Style */
  .nav-item.highlight .img-wrapper {
    border-color: {{ section.settings.highlight_color }};
  }

  .nav-item:hover .img-wrapper {
    transform: scale(1.05);
  }

  .img-wrapper img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 50%;
    display: block;
  }

  .nav-label {
    font-family: var(--font-body-family); /* Use theme font */
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    color: {{ section.settings.text_color }};
    text-align: center;
    letter-spacing: 0.5px;
    line-height: 1.2;
  }
</style>

<div class="story-nav-container">
  <div class="nav-list">
    {% for block in section.blocks %}
      {% if block.settings.image != blank %}
        <a href="{{ block.settings.link }}" class="nav-item{% if block.settings.is_highlighted %} highlight{% endif %}" {{ block.shopify_attributes }}>
          <div class="img-wrapper">
            {{ block.settings.image | image_url: width: 200 | image_tag: loading: 'lazy', alt: block.settings.title }}
          </div>
          <span class="nav-label">{{ block.settings.title }}</span>
        </a>
      {% endif %}
    {% endfor %}
  </div>
</div>

{% schema %}
{
  "name": "Story Navigation",
  "settings": [
    {
      "type": "header",
      "content": "Visibility Settings"
    },
    {
      "type": "select",
      "id": "visibility",
      "label": "Show on Device",
      "options": [
        { "value": "both", "label": "Both Mobile & Desktop" },
        { "value": "mobile", "label": "Mobile Only" },
        { "value": "desktop", "label": "Desktop Only" }
      ],
      "default": "both",
      "info": "Choose which devices will display this section."
    },
    {
      "type": "header",
      "content": "Layout & Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#333333"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Default Border Color",
      "default": "#E0E0E0"
    },
    {
      "type": "color",
      "id": "highlight_color",
      "label": "Highlight Border Color",
      "default": "#FF4D4D",
      "info": "Used when 'Highlight this item' is checked in block settings."
    },
    {
      "type": "range",
      "id": "image_size",
      "min": 50,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Image Size",
      "default": 70
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 60,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 60,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 20
    },
    {
      "type": "select",
      "id": "alignment",
      "label": "Alignment",
      "options": [
        { "value": "flex-start", "label": "Left" },
        { "value": "center", "label": "Center" }
      ],
      "default": "flex-start"
    }
  ],
  "blocks": [
    {
      "type": "nav_item",
      "name": "Story Item",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Label",
          "default": "Collection"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        },
        {
          "type": "checkbox",
          "id": "is_highlighted",
          "label": "Highlight this item",
          "default": false,
          "info": "Adds a colored border (e.g., for Sales or Valentine's)."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Story Navigation",
      "blocks": [
        { "type": "nav_item" },
        { "type": "nav_item" },
        { "type": "nav_item" },
        { "type": "nav_item" }
      ]
    }
  ]
}
{% endschema %}