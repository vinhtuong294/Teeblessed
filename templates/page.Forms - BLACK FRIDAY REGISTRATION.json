      "name": "Running Marquee",
      "settings": {
        "custom_html": "<meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Running Information Bar Marquee (Native CSS)</title>\n    \n    <style>\n        @media (min-width: 761px)\n        {\n            .info-bar-container {\n                margin-top: -45px;\n            }\n        }\n        \n        /* Marquee Container Styling (Equivalent to Tailwind classes) */\n        .info-bar-container {\n            width: 100%;\n            background-color: #000000; /* Equivalent to bg-gray-900 */\n            color: rgb(255, 0, 0);\n            padding-top: 0.25rem; /* Equivalent to py-3 */\n            padding-bottom: 0.25rem; /* Equivalent to py-3 */\n            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -2px rgba(0, 0, 0, 0.06); /* Equivalent to shadow-lg */\n        }\n\n        /* Marquee Mechanism CSS */\n        .marquee-container {\n            /* Hides content overflowing the container */\n            overflow: hidden;\n            white-space: nowrap;\n        }\n\n        .marquee-content {\n            /* This is the key to the animation. It ensures the content strip is longer than the container */\n            display: inline-block;\n            /* Start position for the animation */\n            transform: translateX(0);\n            /* Apply the continuous scroll animation */\n            animation: continuousScroll 30s linear infinite;\n        }\n\n        /* Define the animation keyframes */\n        @keyframes continuousScroll {\n            /* Start the content on the right edge of the screen */\n            0% {\n                transform: translateX(0%);\n            }\n            /* End the content off the left edge of the screen */\n            100% {\n                transform: translateX(-50%); /* Move exactly 50% to scroll the content strip once */\n            }\n        }\n\n        /* Pause animation on hover */\n        .marquee-container:hover .marquee-content {\n            animation-play-state: paused;\n        }\n\n        /* Styling for each item and the inner container */\n        .marquee-inner-flex {\n            display: flex;\n            flex-direction: row;\n            align-items: center;\n        }\n\n        .marquee-item {\n            display: flex;\n            align-items: center;\n            font-size: 1.25rem; /* text-sm */\n            font-weight: Bold; /* font-medium */\n            letter-spacing: 0.025em; /* tracking-wide */\n            margin-left: 2rem; /* mx-8 */\n            margin-right: 2rem; /* mx-8 */\n        }\n        @media (max-width: 760px) {\n            .marquee-item {\n                font-size: 1rem;\n            }\n        }\n\n        .item-icon {\n            font-size: 1.125rem; /* text-lg */\n            margin-right: 0.5rem; /* mr-2 */\n        }\n\n        /* Color Utility Classes */\n        .text-green-400 { color: #4ade80; }\n        .text-blue-400 { color: #60a5fa; }\n        .text-red-400 { color: #f87171; }\n\n        /* Style for the decorative separator dot */\n        .separator {\n            content: \"\";\n            display: inline-block;\n            width: 4px;\n            height: 4px;\n            background-color: #888;\n            border-radius: 50%;\n            margin-left: 1.5rem;\n            vertical-align: middle;\n        }\n\n        /* Demo Content Styling */\n        .demo-content {\n            padding: 2rem;\n            text-align: center;\n            color: #374151; /* text-gray-700 */\n        }\n        .demo-content h1 {\n            font-size: 1.875rem; /* text-3xl */\n            font-weight: 700; /* font-bold */\n            margin-bottom: 1rem; /* mb-4 */\n        }\n\n    </style>\n\n\n\n    <!-- Information Bar Container -->\n    <div class=\"info-bar-container\">\n        <div id=\"marqueeContainer\" class=\"marquee-container\">\n            <div id=\"marqueeContent\" class=\"marquee-content\">\n                <!-- Content will be injected by JavaScript -->\n            </div>\n        </div>\n    </div>\n\n    <script src=\"https://cdn.shopify.com/s/files/1/0740/5879/3017/files/marquee2.js?v=1763546507\">\n            </script>",
