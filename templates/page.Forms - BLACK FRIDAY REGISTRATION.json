      "name": "Countdown Timer",
      "settings": {
        "custom_html": "<meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Countdown Timer</title>\n\n\n    \n<h2 id=\"b\"> Black Friday 2025 countdown</h2>\n    <div id=\"countdown-container\">\n        <div class=\"time-block\" style=\"margin-left:10px;\">\n            <span id=\"days\" class=\"time-value\">00</span>\n            <span class=\"time-label\">Days</span>\n        </div>\n        <div class=\"time-block\">\n            <span id=\"hours\" class=\"time-value\">00</span>\n            <span class=\"time-label\">Hours</span>\n        </div>\n        <div class=\"time-block\">\n            <span id=\"minutes\" class=\"time-value\">00</span>\n            <span class=\"time-label\">Minutes</span>\n        </div>\n        <div class=\"time-block\" style=\"margin-right:10px;\">\n            <span id=\"seconds\" class=\"time-value\">00</span>\n            <span class=\"time-label\">Seconds</span>\n        </div>\n    </div>\n\n\n\n<style>\n    /* @media (max-width: 760px)\n    {\n        #countdown-container {\n            transform: scale(0.2);\n        }\n        \n    } */\n    /* --- Google Font Import --- */\n/* (This is also in the HTML <head> as a backup) */\n@import url('https://fonts.googleapis.com/css2?family=Montserrat:wght@400;700&display=swap');\n\n/* --- Basic page setup --- */\nbody {\n    font-family: 'Montserrat', sans-serif; /* Clean, premium font */\n    background-color: #ffffff; /* Deep black for Black Friday */\n    color: #f0f0f0;\n    display: flex;\n    flex-direction: column;\n    justify-content: center;\n    align-items: center;\n    min-height: 100vh;\n    margin: 0;\n    \n}\n\n#b {\n    text-align: center;\n    color: #e61b1b;\n    font-size: 2rem;\n    text-shadow: 0 0 10px rgba(169, 62, 16, 0.4);\n}\n\n/* --- Main container for the timer blocks --- */\n#countdown-container {\n    display: flex;\n    gap: 20px;\n    justify-content: center;\n    flex-wrap: nowrap; /* Không wrap */\n    width: 100%;\n    transition: transform 0.3s ease; /* Thêm hiệu ứng chuyển đổi */\n}\n\n#countdown-container > div {\n    flex-grow: 1;\n    max-width: 200px;\n}\n\n@media (max-width: 480px) {\n    #countdown-container {\n        transform: scale(0.7);  /* Thu nhỏ toàn bộ div với tỷ lệ 80% khi màn hình nhỏ hơn 768px */\n        gap: 10px;  /* Giảm khoảng cách giữa các phần tử khi màn hình nhỏ */\n    }\n    .time-block {\n        transform: scale(1);\n        padding: 0px 0px;\n    }\n    .time-value {\n        transform: scale(0.7);\n    }\n    .time-label {\n        transform: scale(0.7);\n    }\n    #b {\n        margin-top: 10px;\n        font-size: 1.5rem;\n    }\n\n}\n\n\n/* --- Individual time block (Days, Hours, etc.) --- */\n.time-block {\n    background-color: #111; /* Very dark gray, just off-black */\n    padding: 20px 30px;\n    border-radius: 8px;\n    text-align: center;\n    \n    /* A solid gold border */\n    border: 2px solid #e61b1b;\n    /* A subtle glow effect from the gold border */\n    box-shadow: 0 0 20px rgba(169, 62, 16, 0.4);\n    transition: transform 0.2s ease, box-shadow 0.2s ease;\n}\n\n\n/* --- The large number (e.g., \"00\") --- */\n.time-value {\n    font-family: 'Montserrat', sans-serif;\n    font-size: 3.5rem;\n    font-weight: 700;\n    color: #FFFFFF; /* Bright white for high contrast */\n    display: block;\n    line-height: 1.2;\n}\n\n/* --- The small label (e.g., \"Days\") --- */\n.time-label {\n    font-family: 'Montserrat', sans-serif;\n    font-size: 0.9rem;\n    font-weight: 400;\n    text-transform: uppercase;\n    color: #e61b1b; /* Gold to match the title and border */\n    letter-spacing: 1.5px;\n}\n</style>\n<script src=\"https://cdn.shopify.com/s/files/1/0740/5879/3017/files/dongho_b7c2ae5a-b5ac-447e-b1e6-04084913faaa.js?v=1763612745\">\n\n</script>",
        "spacing_desktop": 50,
        "spacing_mobile": 10,
        "fix_zindex": 0
      }
