            "custom_liquid": "<link href=\"https://fonts.googleapis.com/css2?family=Roboto:wght@700;800&display=swap\" rel=\"stylesheet\">\n\n<div class=\"flash-sale-container\">\n  <div class=\"fs-left\">\n    <span class=\"fs-highlight\">FLASH SALE</span>\n  </div>\n  <div class=\"fs-right\">\n    <span id=\"countdown-clock\">45 : 00</span>\n  </div>\n</div>\n<style>\n  .flash-sale-container {\n    display: inline-flex;\n    align-items: stretch;\n    border: 1.5px solid #f40c1d;\n    border-radius: 4px;\n    overflow: hidden;\n    font-family: 'Roboto', sans-serif;\n    font-style: italic;\n    margin: 10px 0;\n  }\n  .fs-left {\n    background-color: #f40c1d;\n    color: #ffffff;\n    padding: 4px 6px;\n    display: flex;\n    align-items: center;\n  }\n  .fs-highlight {\n    font-family: 'Roboto', sans-serif;\n    font-weight: 800;\n    font-size: 0.72rem;\n    line-height: 1;\n    letter-spacing: 0px;\n    font-style: italic;\n  }\n  .fs-right {\n    background-color: #FFF9F9;\n    color: #f40c1d;\n    padding: 4px 8px;\n    display: flex;\n    align-items: center;\n  }\n  #countdown-clock {\n    font-family: 'Roboto', sans-serif;\n    font-weight: 700;\n    font-size: 0.92rem;\n    line-height: 1;\n    letter-spacing: 0px;\n    display: inline-block;\n    font-style: italic;\n  }\n</style>\n<script>\n(function() {\n  const MINUTES_LIMIT = 45; \n  const STORAGE_KEY = 'shopify_flash_sale_timestamp';\n  function startCountdown() {\n    let endTime = localStorage.getItem(STORAGE_KEY);\n    const now = new Date().getTime();\n    if (!endTime || now > parseInt(endTime)) {\n      endTime = now + (MINUTES_LIMIT * 60 * 1000);\n      localStorage.setItem(STORAGE_KEY, endTime);\n    }\n    const clockElement = document.getElementById('countdown-clock');\n    if (!clockElement) return;\n    const updateClock = setInterval(function() {\n      const currentTime = new Date().getTime();\n      const distance = parseInt(endTime) - currentTime;\n      if (distance <= 0) {\n        clearInterval(updateClock);\n        clockElement.innerHTML = \"00 : 00\";\n        return;\n      }\n      const minutes = Math.floor(distance / (1000 * 60));\n      const seconds = Math.floor((distance % (1000 * 60)) / 1000);\n      const mDisplay = minutes < 10 ? \"0\" + minutes : minutes;\n      const sDisplay = seconds < 10 ? \"0\" + seconds : seconds;\n      clockElement.innerHTML = mDisplay + \" : \" + sDisplay;\n    }, 1000);\n  }\n  if (document.readyState === 'complete' || document.readyState === 'interactive') {\n    startCountdown();\n  } else {\n    document.addEventListener('DOMContentLoaded', startCountdown);\n  }\n})();\n</script>"
